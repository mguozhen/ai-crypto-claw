# OKX API credentials (get from https://www.okx.com/account/my-api)
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here

# Set to 1 for paper trading (demo), 0 for live trading
OKX_DEMO_MODE=1

# Telegram bot for notifications + account management
# Create bot: https://t.me/BotFather -> /newbot
# Get chat ID: https://t.me/userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Encryption key for sub-account credentials
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Dashboard login password
DASHBOARD_PASSWORD=admin123
